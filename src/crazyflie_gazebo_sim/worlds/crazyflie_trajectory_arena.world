<?xml version="1.0"?>
<!--
  Crazyflie Trajectory Tracking Arena
  A clean, flat indoor environment for trajectory tracking experiments.
  Includes coordinate frame markers for easy visualization.
-->
<sdf version="1.6">
  <world name="crazyflie_trajectory_arena">

    <!-- Physics: tuned for small, fast quadrotor -->
    <physics name="arena_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>100</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- Lighting -->
    <light name="arena_sunlight" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>
    <light name="arena_ambient" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 5 0 0 0</pose>
      <diffuse>0.4 0.4 0.4 1</diffuse>
      <specular>0 0 0 1</specular>
      <direction>0 0 -1</direction>
    </light>

    <!-- Ground plane -->
    <model name="arena_ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry><plane><normal>0 0 1</normal><size>10 10</size></plane></geometry>
          <surface>
            <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="ground_visual">
          <geometry><plane><normal>0 0 1</normal><size>10 10</size></plane></geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Arena boundary walls (5m x 5m x 2m) -->
    <!-- Wall North -->
    <model name="arena_wall_north">
      <static>true</static>
      <pose>0 2.5 1.0 0 0 0</pose>
      <link name="wall_link">
        <collision name="wall_col"><geometry><box><size>5 0.05 2</size></box></geometry></collision>
        <visual name="wall_vis">
          <geometry><box><size>5 0.05 2</size></box></geometry>
          <material><ambient>0.8 0.8 0.9 0.3</ambient><diffuse>0.8 0.8 0.9 0.3</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Wall South -->
    <model name="arena_wall_south">
      <static>true</static>
      <pose>0 -2.5 1.0 0 0 0</pose>
      <link name="wall_link">
        <collision name="wall_col"><geometry><box><size>5 0.05 2</size></box></geometry></collision>
        <visual name="wall_vis">
          <geometry><box><size>5 0.05 2</size></box></geometry>
          <material><ambient>0.8 0.8 0.9 0.3</ambient><diffuse>0.8 0.8 0.9 0.3</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Wall East -->
    <model name="arena_wall_east">
      <static>true</static>
      <pose>2.5 0 1.0 0 0 0</pose>
      <link name="wall_link">
        <collision name="wall_col"><geometry><box><size>0.05 5 2</size></box></geometry></collision>
        <visual name="wall_vis">
          <geometry><box><size>0.05 5 2</size></box></geometry>
          <material><ambient>0.8 0.8 0.9 0.3</ambient><diffuse>0.8 0.8 0.9 0.3</diffuse></material>
        </visual>
      </link>
    </model>
    <!-- Wall West -->
    <model name="arena_wall_west">
      <static>true</static>
      <pose>-2.5 0 1.0 0 0 0</pose>
      <link name="wall_link">
        <collision name="wall_col"><geometry><box><size>0.05 5 2</size></box></geometry></collision>
        <visual name="wall_vis">
          <geometry><box><size>0.05 5 2</size></box></geometry>
          <material><ambient>0.8 0.8 0.9 0.3</ambient><diffuse>0.8 0.8 0.9 0.3</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Crazyflie 2.1 spawned at origin, 5cm above ground -->
    <include>
      <uri>model://crazyflie_2_1</uri>
      <name>crazyflie_2_1</name>
      <pose>0 0 0.05 0 0 0</pose>
    </include>

    <!-- ROS2 Gazebo plugins -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <remapping>model_states:=gazebo/model_states</remapping>
        <remapping>link_states:=gazebo/link_states</remapping>
      </ros>
      <update_rate>100.0</update_rate>
    </plugin>

    <plugin name="gazebo_ros_factory" filename="libgazebo_ros_factory.so"/>

  </world>
</sdf>
